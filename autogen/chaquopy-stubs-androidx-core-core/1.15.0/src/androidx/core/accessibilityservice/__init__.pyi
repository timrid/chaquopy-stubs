    CAPABILITY_CAN_REQUEST_ENHANCED_WEB_ACCESSIBILITY: typing.ClassVar[int] = ...
    CAPABILITY_CAN_FILTER_KEY_EVENTS: typing.ClassVar[int] = ...
    FEEDBACK_BRAILLE: typing.ClassVar[int] = ...
