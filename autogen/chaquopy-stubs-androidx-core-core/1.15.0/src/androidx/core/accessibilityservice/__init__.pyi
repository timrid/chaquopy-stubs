    FLAG_INCLUDE_NOT_IMPORTANT_VIEWS: typing.ClassVar[int] = ...
    FLAG_REQUEST_TOUCH_EXPLORATION_MODE: typing.ClassVar[int] = ...
    FLAG_REQUEST_ENHANCED_WEB_ACCESSIBILITY: typing.ClassVar[int] = ...
    FLAG_REPORT_VIEW_IDS: typing.ClassVar[int] = ...
    FLAG_REQUEST_FILTER_KEY_EVENTS: typing.ClassVar[int] = ...
