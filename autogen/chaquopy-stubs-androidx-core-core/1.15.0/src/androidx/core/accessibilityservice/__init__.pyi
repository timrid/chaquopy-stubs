    def capabilityToString(capability: int | java.jint | java.lang.Integer, /) -> str: ...
    @staticmethod
    def feedbackTypeToString(feedbackType: int | java.jint | java.lang.Integer, /) -> str: ...
    @staticmethod
    def flagToString(flag: int | java.jint | java.lang.Integer, /) -> str: ...
