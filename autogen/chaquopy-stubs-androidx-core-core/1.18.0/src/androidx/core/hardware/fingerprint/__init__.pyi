import typing

import android.content
import android.os
import androidx.core.os
import java
import java.lang
import java.security
import javax.crypto

class FingerprintManagerCompat(java.lang.Object):
    @typing.overload
    def authenticate(self, crypto: FingerprintManagerCompat.CryptoObject, flags: int | java.jint | java.lang.Integer, cancel: android.os.CancellationSignal, callback: FingerprintManagerCompat.AuthenticationCallback, handler: android.os.Handler, /) -> None: ...
    @typing.overload
    def authenticate(self, crypto: FingerprintManagerCompat.CryptoObject, flags: int | java.jint | java.lang.Integer, cancel: androidx.core.os.CancellationSignal, callback: FingerprintManagerCompat.AuthenticationCallback, handler: android.os.Handler, /) -> None: ...
    @staticmethod
    def from_(context: android.content.Context, /) -> FingerprintManagerCompat: ...
    def hasEnrolledFingerprints(self) -> bool: ...
    def isHardwareDetected(self) -> bool: ...

    class AuthenticationCallback(java.lang.Object):
        def __init__(self) -> None: ...
        def onAuthenticationError(self, errMsgId: int | java.jint | java.lang.Integer, errString: java.lang.CharSequence, /) -> None: ...
        def onAuthenticationFailed(self) -> None: ...
        def onAuthenticationHelp(self, helpMsgId: int | java.jint | java.lang.Integer, helpString: java.lang.CharSequence, /) -> None: ...
        def onAuthenticationSucceeded(self, result: FingerprintManagerCompat.AuthenticationResult, /) -> None: ...

    class AuthenticationResult(java.lang.Object):
        def __init__(self, crypto: FingerprintManagerCompat.CryptoObject, /) -> None: ...
        def getCryptoObject(self) -> FingerprintManagerCompat.CryptoObject: ...

    class CryptoObject(java.lang.Object):
        @typing.overload
        def __init__(self, signature: java.security.Signature, /) -> None: ...
        @typing.overload
        def __init__(self, cipher: javax.crypto.Cipher, /) -> None: ...
        @typing.overload
        def __init__(self, mac: javax.crypto.Mac, /) -> None: ...
        def getCipher(self) -> javax.crypto.Cipher: ...
        def getMac(self) -> javax.crypto.Mac: ...
        def getSignature(self) -> java.security.Signature: ...
