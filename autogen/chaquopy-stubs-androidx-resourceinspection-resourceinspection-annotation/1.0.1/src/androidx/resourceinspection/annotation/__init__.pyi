import java.chaquopy
import java.lang.annotation

class AppCompatShadowedAttributes(java.lang.annotation.Annotation): ...

class Attribute(java.lang.annotation.Annotation):
    def intMapping(self) -> java.chaquopy.JavaArray[Attribute.IntMap]: ...
    def value(self) -> str: ...

    class IntMap(java.lang.annotation.Annotation):
        def mask(self) -> int: ...
        def name(self) -> str: ...
        def value(self) -> int: ...
