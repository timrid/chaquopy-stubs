import typing

import android.app
import android.content
import android.os
import androidx
import androidx.startup
import java.lang
import java.util

class EmptyActivityLifecycleCallbacks(android.app.Application.ActivityLifecycleCallbacks):
    def onActivityCreated(self, activity: android.app.Activity, savedInstanceState: android.os.Bundle, /) -> None: ...
    def onActivityDestroyed(self, activity: android.app.Activity, /) -> None: ...
    def onActivityPaused(self, activity: android.app.Activity, /) -> None: ...
    def onActivityResumed(self, activity: android.app.Activity, /) -> None: ...
    def onActivitySaveInstanceState(self, activity: android.app.Activity, outState: android.os.Bundle, /) -> None: ...
    def onActivityStarted(self, activity: android.app.Activity, /) -> None: ...
    def onActivityStopped(self, activity: android.app.Activity, /) -> None: ...

class LifecycleDispatcher(java.lang.Object): ...

class ProcessLifecycleInitializer(androidx.startup.Initializer[LifecycleOwner]):
    def __init__(self) -> None: ...
    def create(self, context: android.content.Context, /) -> LifecycleOwner: ...
    def dependencies(self) -> java.util.List[typing.Type[androidx.startup.Initializer[java.lang.Object]]]: ...

class ProcessLifecycleOwner(androidx.lifecycle.LifecycleOwner):
    @staticmethod
    def get() -> LifecycleOwner: ...
    def getLifecycle(self) -> Lifecycle: ...
