import android.content
import java.lang

class ContextAware(java.lang.Object):
    def addOnContextAvailableListener(self, arg1: OnContextAvailableListener, /) -> None: ...
    def peekAvailableContext(self) -> android.content.Context: ...
    def removeOnContextAvailableListener(self, arg1: OnContextAvailableListener, /) -> None: ...

class ContextAwareHelper(java.lang.Object):
    def __init__(self) -> None: ...
    def addOnContextAvailableListener(self, listener: OnContextAvailableListener, /) -> None: ...
    def clearAvailableContext(self) -> None: ...
    def dispatchOnContextAvailable(self, context: android.content.Context, /) -> None: ...
    def peekAvailableContext(self) -> android.content.Context: ...
    def removeOnContextAvailableListener(self, listener: OnContextAvailableListener, /) -> None: ...

class OnContextAvailableListener(java.lang.Object):
    def onContextAvailable(self, arg1: android.content.Context, /) -> None: ...
