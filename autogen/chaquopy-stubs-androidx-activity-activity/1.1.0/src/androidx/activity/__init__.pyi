    def addCallback(self, owner: androidx.lifecycle.LifecycleOwner, onBackPressedCallback: OnBackPressedCallback, /) -> None: ...
    def hasEnabledCallbacks(self) -> bool: ...
    def onBackPressed(self) -> None: ...

