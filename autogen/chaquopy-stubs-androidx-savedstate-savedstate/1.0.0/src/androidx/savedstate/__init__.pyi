import typing

import android.os
import androidx.lifecycle
import java.lang

class Recreator(androidx.lifecycle.GenericLifecycleObserver):
    def onStateChanged(self, source: androidx.lifecycle.LifecycleOwner, event: androidx.lifecycle.Lifecycle.Event, /) -> None: ...

class SavedStateRegistry(java.lang.Object):
    def consumeRestoredStateForKey(self, key: str | java.lang.String, /) -> android.os.Bundle: ...
    def isRestored(self) -> bool: ...
    def registerSavedStateProvider(self, key: str | java.lang.String, provider: SavedStateRegistry.SavedStateProvider, /) -> None: ...
    def runOnNextRecreation(self, clazz: typing.Type[SavedStateRegistry.AutoRecreated], /) -> None: ...
    def unregisterSavedStateProvider(self, key: str | java.lang.String, /) -> None: ...

    class SavedStateProvider(java.lang.Object):
        def saveState(self) -> android.os.Bundle: ...

    class AutoRecreated(java.lang.Object):
        def onRecreated(self, arg1: SavedStateRegistryOwner, /) -> None: ...

class SavedStateRegistryController(java.lang.Object):
    @staticmethod
    def create(owner: SavedStateRegistryOwner, /) -> SavedStateRegistryController: ...
    def getSavedStateRegistry(self) -> SavedStateRegistry: ...
    def performRestore(self, savedState: android.os.Bundle, /) -> None: ...
    def performSave(self, outBundle: android.os.Bundle, /) -> None: ...

class SavedStateRegistryOwner(androidx.lifecycle.LifecycleOwner):
    def getSavedStateRegistry(self) -> SavedStateRegistry: ...
