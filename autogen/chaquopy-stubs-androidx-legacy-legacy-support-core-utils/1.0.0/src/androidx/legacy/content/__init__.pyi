import android.content

class WakefulBroadcastReceiver(android.content.BroadcastReceiver):
    def __init__(self) -> None: ...
    @staticmethod
    def completeWakefulIntent(intent: android.content.Intent, /) -> bool: ...
    @staticmethod
    def startWakefulService(context: android.content.Context, intent: android.content.Intent, /) -> android.content.ComponentName: ...
