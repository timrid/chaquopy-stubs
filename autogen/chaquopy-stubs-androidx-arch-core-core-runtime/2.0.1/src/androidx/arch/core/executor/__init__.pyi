import java.lang
import java.util.concurrent

class ArchTaskExecutor(TaskExecutor):
    def executeOnDiskIO(self, runnable: java.lang.Runnable, /) -> None: ...
    @staticmethod
    def getIOThreadExecutor() -> java.util.concurrent.Executor: ...
    @staticmethod
    def getInstance() -> ArchTaskExecutor: ...
    @staticmethod
    def getMainThreadExecutor() -> java.util.concurrent.Executor: ...
    def isMainThread(self) -> bool: ...
    def postToMainThread(self, runnable: java.lang.Runnable, /) -> None: ...
    def setDelegate(self, taskExecutor: TaskExecutor, /) -> None: ...

class DefaultTaskExecutor(TaskExecutor):
    def __init__(self) -> None: ...
    def executeOnDiskIO(self, runnable: java.lang.Runnable, /) -> None: ...
    def isMainThread(self) -> bool: ...
    def postToMainThread(self, runnable: java.lang.Runnable, /) -> None: ...

class TaskExecutor(java.lang.Object):
    def __init__(self) -> None: ...
    def executeOnDiskIO(self, arg1: java.lang.Runnable, /) -> None: ...
    def executeOnMainThread(self, runnable: java.lang.Runnable, /) -> None: ...
    def isMainThread(self) -> bool: ...
    def postToMainThread(self, arg1: java.lang.Runnable, /) -> None: ...
