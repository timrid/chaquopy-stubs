import typing

import java
import java.chaquopy
import java.lang
import java.lang.annotation
import kotlin
import kotlin.enums

class CallsInPlace(Effect): ...

class ConditionalEffect(Effect): ...

class ContractBuilder(java.lang.Object):
    def callsInPlace(self, arg1: kotlin.Function[java.lang.Object], arg2: InvocationKind, /) -> CallsInPlace: ...
    def holdsIn(self, arg1: bool | java.jboolean | java.lang.Boolean, arg2: kotlin.Function[java.lang.Object], /) -> HoldsIn: ...
    def implies(self, arg1: bool | java.jboolean | java.lang.Boolean, arg2: ReturnsNotNull, /) -> None: ...
    @typing.overload
    def returns(self) -> Returns: ...
    @typing.overload
    def returns(self, arg1: java.lang.Object | int | bool | float | str, /) -> Returns: ...
    def returnsNotNull(self) -> ReturnsNotNull: ...

    class DefaultImpls(java.lang.Object): ...

class ContractBuilderKt(java.lang.Object): ...

class Effect(java.lang.Object): ...

class ExperimentalContracts(java.lang.annotation.Annotation): ...

class ExperimentalExtendedContracts(java.lang.annotation.Annotation): ...

class HoldsIn(Effect): ...

class InvocationKind(java.lang.Enum[InvocationKind]):
    AT_MOST_ONCE: typing.ClassVar[InvocationKind] = ...
    AT_LEAST_ONCE: typing.ClassVar[InvocationKind] = ...
    EXACTLY_ONCE: typing.ClassVar[InvocationKind] = ...
    UNKNOWN: typing.ClassVar[InvocationKind] = ...
    @staticmethod
    def getEntries() -> kotlin.enums.EnumEntries[InvocationKind]: ...
    @staticmethod
    def valueOf(value: str | java.lang.String, /) -> InvocationKind: ...
    @staticmethod
    def values() -> java.chaquopy.JavaArray[InvocationKind]: ...

class Returns(SimpleEffect): ...

class ReturnsNotNull(SimpleEffect): ...

class SimpleEffect(Effect):
    def implies(self, arg1: bool | java.jboolean | java.lang.Boolean, /) -> ConditionalEffect: ...
