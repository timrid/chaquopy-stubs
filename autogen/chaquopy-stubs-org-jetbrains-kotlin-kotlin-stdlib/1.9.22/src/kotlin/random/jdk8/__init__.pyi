import typing

import java
import java.lang
import java.util
import kotlin.random

class PlatformThreadLocalRandom(kotlin.random.AbstractPlatformRandom):
    def __init__(self) -> None: ...
    def getImpl(self) -> java.util.Random: ...
    def nextDouble(self, until: float | java.jdouble | java.lang.Double, /) -> float: ...
    def nextInt(self, from_: int | java.jint | java.lang.Integer, until: int | java.jint | java.lang.Integer, /) -> int: ...
    @typing.overload
    def nextLong(self, until: int | java.jlong | java.lang.Long, /) -> int: ...
    @typing.overload
    def nextLong(self, from_: int | java.jlong | java.lang.Long, until: int | java.jlong | java.lang.Long, /) -> int: ...
