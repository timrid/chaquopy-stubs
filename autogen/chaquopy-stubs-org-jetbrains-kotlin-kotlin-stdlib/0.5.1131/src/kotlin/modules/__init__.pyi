import java.lang
import java.util
import jet
import jet.modules

class AnnotationsPathBuilder(jet.JetObject):
    def __init__(self, parent: ModuleBuilder, /) -> None: ...
    def getParent(self) -> ModuleBuilder: ...
    def plusAssign(self, name: str | java.lang.String, /) -> None: ...

class ClasspathBuilder(jet.JetObject):
    def __init__(self, parent: ModuleBuilder, /) -> None: ...
    def getParent(self) -> ModuleBuilder: ...
    def plusAssign(self, name: str | java.lang.String, /) -> None: ...

class ModuleBuilder(jet.JetObject, jet.modules.Module):
    def __init__(self, name: str | java.lang.String, /) -> None: ...
    def addAnnotationsPathEntry(self, name: str | java.lang.String, /) -> None: ...
    def addClasspathEntry(self, name: str | java.lang.String, /) -> None: ...
    def addSourceFiles(self, pattern: str | java.lang.String, /) -> None: ...
    def getAnnotationsPath(self) -> AnnotationsPathBuilder: ...
    def getAnnotationsRoots(self) -> java.util.List[java.lang.String]: ...
    def getClasspath(self) -> ClasspathBuilder: ...
    def getClasspathRoots(self) -> java.util.List[java.lang.String]: ...
    def getModuleName(self) -> str: ...
    def getName(self) -> str: ...
    def getSourceFiles(self) -> java.util.List[java.lang.String]: ...
    def getSources(self) -> SourcesBuilder: ...

class ModulesPackage(java.lang.Object):
    @staticmethod
    def module(name: str | java.lang.String, callback: jet.ExtensionFunction0[ModuleBuilder, jet.Unit], /) -> None: ...

class SourcesBuilder(jet.JetObject):
    def __init__(self, parent: ModuleBuilder, /) -> None: ...
    def getParent(self) -> ModuleBuilder: ...
    def plusAssign(self, pattern: str | java.lang.String, /) -> None: ...
