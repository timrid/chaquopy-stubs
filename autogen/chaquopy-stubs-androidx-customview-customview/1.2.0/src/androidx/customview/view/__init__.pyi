import typing

import android.os
import java
import java.lang

class AbsSavedState(android.os.Parcelable):
    EMPTY_STATE: typing.ClassVar[AbsSavedState] = ...
    CREATOR: typing.ClassVar[android.os.Parcelable.Creator[AbsSavedState]] = ...
    @typing.overload
    def __init__(self, source: android.os.Parcel, /) -> None: ...
    @typing.overload
    def __init__(self, superState: android.os.Parcelable, /) -> None: ...
    @typing.overload
    def __init__(self, source: android.os.Parcel, loader: java.lang.ClassLoader, /) -> None: ...
    def describeContents(self) -> int: ...
    def getSuperState(self) -> android.os.Parcelable: ...
    def writeToParcel(self, dest: android.os.Parcel, flags: int | java.jint | java.lang.Integer, /) -> None: ...
