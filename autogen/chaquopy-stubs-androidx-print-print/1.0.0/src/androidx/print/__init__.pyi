import typing

import android.content
import android.graphics
import android.net
import java
import java.lang

class PrintHelper(java.lang.Object):
    SCALE_MODE_FIT: typing.ClassVar[int] = ...
    SCALE_MODE_FILL: typing.ClassVar[int] = ...
    COLOR_MODE_MONOCHROME: typing.ClassVar[int] = ...
    COLOR_MODE_COLOR: typing.ClassVar[int] = ...
    ORIENTATION_LANDSCAPE: typing.ClassVar[int] = ...
    ORIENTATION_PORTRAIT: typing.ClassVar[int] = ...
    def __init__(self, context: android.content.Context, /) -> None: ...
    def getColorMode(self) -> int: ...
    def getOrientation(self) -> int: ...
    def getScaleMode(self) -> int: ...
    @typing.overload
    def printBitmap(self, jobName: str | java.lang.String, bitmap: android.graphics.Bitmap, /) -> None: ...
    @typing.overload
    def printBitmap(self, jobName: str | java.lang.String, imageFile: android.net.Uri, /) -> None: ...
    @typing.overload
    def printBitmap(self, jobName: str | java.lang.String, bitmap: android.graphics.Bitmap, callback: PrintHelper.OnPrintFinishCallback, /) -> None: ...
    @typing.overload
    def printBitmap(self, jobName: str | java.lang.String, imageFile: android.net.Uri, callback: PrintHelper.OnPrintFinishCallback, /) -> None: ...
    def setColorMode(self, colorMode: int | java.jint | java.lang.Integer, /) -> None: ...
    def setOrientation(self, orientation: int | java.jint | java.lang.Integer, /) -> None: ...
    def setScaleMode(self, scaleMode: int | java.jint | java.lang.Integer, /) -> None: ...
    @staticmethod
    def systemSupportsPrint() -> bool: ...

    class OnPrintFinishCallback(java.lang.Object):
        def onFinish(self) -> None: ...
