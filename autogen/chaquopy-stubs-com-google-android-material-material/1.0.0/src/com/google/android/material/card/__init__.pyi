import typing

import android.content
import android.content.res
import android.util
import androidx.cardview.widget
import java
import java.lang

class MaterialCardView(androidx.cardview.widget.CardView):
    @typing.overload
    def __init__(self, context: android.content.Context, /) -> None: ...
    @typing.overload
    def __init__(self, context: android.content.Context, attrs: android.util.AttributeSet, /) -> None: ...
    @typing.overload
    def __init__(self, context: android.content.Context, attrs: android.util.AttributeSet, defStyleAttr: int | java.jint | java.lang.Integer, /) -> None: ...
    def getStrokeColor(self) -> int: ...
    def getStrokeWidth(self) -> int: ...
    def setRadius(self, radius: float | java.jfloat | java.lang.Float, /) -> None: ...
    def setStrokeColor(self, strokeColor: int | java.jint | java.lang.Integer, /) -> None: ...
    def setStrokeWidth(self, strokeWidth: int | java.jint | java.lang.Integer, /) -> None: ...

class MaterialCardViewHelper(java.lang.Object):
    def __init__(self, card: MaterialCardView, /) -> None: ...
    def loadFromAttributes(self, attributes: android.content.res.TypedArray, /) -> None: ...
