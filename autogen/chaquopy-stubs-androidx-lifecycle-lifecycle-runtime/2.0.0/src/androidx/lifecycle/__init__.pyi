import android.app
import android.os
import androidx

class LifecycleRegistry(androidx.lifecycle.Lifecycle):
    def __init__(self, provider: LifecycleOwner, /) -> None: ...
    def addObserver(self, observer: LifecycleObserver, /) -> None: ...
    def getCurrentState(self) -> Lifecycle.State: ...
    def getObserverCount(self) -> int: ...
    def handleLifecycleEvent(self, event: Lifecycle.Event, /) -> None: ...
    def markState(self, state: Lifecycle.State, /) -> None: ...
    def removeObserver(self, observer: LifecycleObserver, /) -> None: ...

class LifecycleRegistryOwner(androidx.lifecycle.LifecycleOwner):
    def getLifecycle(self) -> LifecycleRegistry: ...

class ReportFragment(android.app.Fragment):
    def __init__(self) -> None: ...
    @staticmethod
    def injectIfNeededIn(activity: android.app.Activity, /) -> None: ...
    def onActivityCreated(self, savedInstanceState: android.os.Bundle, /) -> None: ...
    def onDestroy(self) -> None: ...
    def onPause(self) -> None: ...
    def onResume(self) -> None: ...
    def onStart(self) -> None: ...
    def onStop(self) -> None: ...
