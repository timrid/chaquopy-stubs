    class PatternFlags(java.lang.annotation.Annotation): ...

    class CalendarMonth(java.lang.annotation.Annotation): ...

    class HorizontalScrollBarPolicy(java.lang.annotation.Annotation): ...

    class VerticalScrollBarPolicy(java.lang.annotation.Annotation): ...

    class AdjustableOrientation(java.lang.annotation.Annotation): ...

    class InputEventMask(java.lang.annotation.Annotation): ...

