import typing

import java.chaquopy
import java.lang
import java.lang.annotation

class Flow(java.lang.annotation.Annotation):
    DEFAULT_SOURCE: typing.ClassVar[str] = ...
    THIS_SOURCE: typing.ClassVar[str] = ...
    DEFAULT_TARGET: typing.ClassVar[str] = ...
    RETURN_METHOD_TARGET: typing.ClassVar[str] = ...
    THIS_TARGET: typing.ClassVar[str] = ...
    def source(self) -> str: ...
    def sourceIsContainer(self) -> bool: ...
    def target(self) -> str: ...
    def targetIsContainer(self) -> bool: ...

class Identifier(java.lang.annotation.Annotation): ...

