    class TabLayoutPolicy(java.lang.annotation.Annotation): ...

    class TabPlacement(java.lang.annotation.Annotation): ...

    class TitledBorderTitlePosition(java.lang.annotation.Annotation): ...

    class TitledBorderJustification(java.lang.annotation.Annotation): ...

    class FontStyle(java.lang.annotation.Annotation): ...

